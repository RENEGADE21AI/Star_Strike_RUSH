{
  "hosting": {
    "target": "app",
    "public": "dist",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git",
      ".git/**",
      ".gitignore",
      ".github",
      ".github/**",
      "**/node_modules/**",
      "functions",
      "functions/**",
      "tests",
      "tests/**",
      "docs",
      "docs/**",
      "scripts",
      "scripts/**",
      "README.md",
      "BUILD_WEEK_2026.md",
      "src/README.md",
      "**/firebase-config*.json",
      "**/firebase-config*.js",
      "source-art",
      "source-art/**",
      "/*.png",
      "firestore.rules",
      "firestore.indexes.json",
      "FIRESTORE_*.md",
      "FIRESTORE_*.json",
      "gameinfo.txt",
      "LICENSE",
      "*-debug.log",
      "firebase-debug.log",
      "firestore-debug.log",
      "ui-debug.log"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' https://www.gstatic.com; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.cloudfunctions.net wss://*.firebaseio.com; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600, must-revalidate"
          }
        ]
      },
      {
        "source": "assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
