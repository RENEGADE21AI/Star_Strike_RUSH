rules_version = '2';

// Cloud Functions use the Admin SDK for every mutation and bypass these rules.
// The browser can read only the minimum data needed by the current UI:
// owner-private progression, authenticated public pilots/leaderboards, and the
// owner's immutable server receipts. Registries and league internals stay
// callable-only so the server can return sanitized competition payloads.

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /players_private/{userId} {
      allow get: if isOwner(userId);
      allow list, create, update, delete: if false;
    }

    match /players_public/{userId} {
      allow get: if signedIn();
      allow list: if signedIn() && request.query.limit <= 25;
      allow create, update, delete: if false;
    }

    match /leaderboard_scores/{userId} {
      allow get: if signedIn();
      allow list: if signedIn() && request.query.limit <= 25;
      allow create, update, delete: if false;
    }

    match /player_achievements/{userId}/items/{achievementId} {
      allow get, list: if isOwner(userId);
      allow create, update, delete: if false;
    }

    // Aggregate state is server-only. The owner-facing UI reads the sanitized
    // individual unlock documents above.
    match /player_achievement_state/{userId} {
      allow read, write: if false;
    }

    match /run_receipts/{userId}/items/{receiptId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId) && request.query.limit <= 50;
      allow create, update, delete: if false;
    }

    match /season_reward_claims/{userId}/items/{rewardId} {
      allow get, list: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /handle_registry/{handle} {
      allow read, write: if false;
    }

    match /weekly_enrollments/{enrollmentId} {
      allow read, write: if false;
    }

    match /weekly_leagues/{leagueId} {
      allow read, write: if false;

      match /members/{userId} {
        allow read, write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
