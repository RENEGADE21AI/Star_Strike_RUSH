rules_version = '2';

// Assumed data model:
// - players_private/{uid}: owner-only account and progression data, including PII.
// - players_public/{uid}, leaderboard_scores/{uid}: authenticated-readable game identity
//   (callSign, handle) and bounded game statistics; never provider identity or email.
// - player_achievements/{uid}/items/{id}, run_receipts/{uid}/items/{id},
//   season_reward_claims/{uid}/items/{id}: owner-readable server records.
// - handle_registry/{handle}: server-only immutable uniqueness registry.
// - weekly_enrollments/{week_uid}: server-only assignment lookup.
// - weekly_leagues/{leagueId}/members/{uid}: server-only competition data returned
//   through authenticated callable functions as a sanitized payload.
// All writes are performed by trusted Cloud Functions with the Admin SDK.

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAuthenticated() {
      return signedIn();
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return signedIn() && request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return request.resource.data.uid == resource.data.uid;
    }

    function hasRequired(data, fields) {
      return data.keys().hasAll(fields);
    }

    function hasOnly(data, fields) {
      return data.keys().hasOnly(fields);
    }

    function validText(value, maxLength) {
      return value is string
        && value.size() <= maxLength
        && value.matches("^[A-Za-z0-9 _.'-]*$");
    }

    function validEmail(value) {
      return value is string
        && value.size() <= 120
        && value.matches("^[A-Za-z0-9@._+-]*$");
    }

    function validCallSign(value) {
      return value is string
        && value.size() <= 12
        && value.matches("^[A-Z0-9_]*$");
    }

    function validHandle(value) {
      return value is string
        && value.size() <= 16
        && (value == "" || value.matches("^[a-z][a-z0-9_]{2,15}$"));
    }

    function validUrl(value) {
      return value is string
        && value.size() <= 300
        && (value == "" || value.matches("^https?://.{1,292}$"));
    }

    function validScore(value) {
      return value is int && value >= 0 && value <= 999999999;
    }

    function validCounter(value) {
      return value is int && value >= 0 && value <= 1000000;
    }

    function validBoundedCounter(value, max) {
      return value is int && value >= 0 && value <= max;
    }

    function validPhase(value) {
      return value is int && value >= 1 && value <= 9999;
    }

    function validGloryRank(value) {
      return value in [
        'Rookie Pilot',
        'Star Cadet',
        'Strike Pilot',
        'Void Runner',
        'Ace',
        'Elite Ace',
        'Phantom Hunter',
        'Wraithbreaker',
        'Solar Legend',
        'Star Eternal'
      ];
    }

    function validGloryRankIndex(value) {
      return value is int && value >= 0 && value <= 9;
    }

    function validSeasonId(value) {
      return value is string
        && value.size() >= 1
        && value.size() <= 40
        && value.matches("^[A-Za-z0-9_-]+$");
    }

    function validSeasonTier(value) {
      return value is int && value >= 1 && value <= 50;
    }

    function validSeasonClaimedRewardIds(value) {
      return value is list && value.size() <= 220;
    }

    function validPrivateAccount(data, userId) {
      return hasRequired(data, [
          'uid',
          'email',
          'displayName',
          'photoURL',
          'glory',
          'gloryRank',
          'gloryRankIndex',
          'currentSeasonId',
          'currentSeasonXP',
          'currentSeasonTier',
          'credits',
          'seasonClaimedRewardIds',
          'lifetimeRuns',
          'lifetimeScore',
          'lifetimeKills',
          'lifetimePowerups',
          'lifetimeGhostUses',
          'lifetimeBosses',
          'lifetimeDamageTaken',
          'highestCombo',
          'createdAt',
          'lastSeenAt',
          'updatedAt'
        ])
        && hasOnly(data, [
          'uid',
          'email',
          'displayName',
          'photoURL',
          'glory',
          'gloryRank',
          'gloryRankIndex',
          'currentSeasonId',
          'currentSeasonXP',
          'currentSeasonTier',
          'credits',
          'seasonClaimedRewardIds',
          'lifetimeRuns',
          'lifetimeScore',
          'lifetimeKills',
          'lifetimePowerups',
          'lifetimeGhostUses',
          'lifetimeBosses',
          'lifetimeDamageTaken',
          'highestCombo',
          'createdAt',
          'lastSeenAt',
          'updatedAt'
        ])
        && data.uid == userId
        && validEmail(data.email)
        && validText(data.displayName, 60)
        && validUrl(data.photoURL)
        && validScore(data.glory)
        && validGloryRank(data.gloryRank)
        && validGloryRankIndex(data.gloryRankIndex)
        && validSeasonId(data.currentSeasonId)
        && validScore(data.currentSeasonXP)
        && validSeasonTier(data.currentSeasonTier)
        && validScore(data.credits)
        && validSeasonClaimedRewardIds(data.seasonClaimedRewardIds)
        && validCounter(data.lifetimeRuns)
        && validScore(data.lifetimeScore)
        && validCounter(data.lifetimeKills)
        && validCounter(data.lifetimePowerups)
        && validCounter(data.lifetimeGhostUses)
        && validCounter(data.lifetimeBosses)
        && validCounter(data.lifetimeDamageTaken)
        && validCounter(data.highestCombo)
        && data.lastSeenAt == request.time
        && data.updatedAt == request.time;
    }

    function validPublicProfile(data, userId) {
      return hasRequired(data, [
          'uid',
          'callSign',
          'handle',
          'bestScore',
          'phase',
          'achievementsCount',
          'glory',
          'gloryRank',
          'gloryRankIndex',
          'seasonTier',
          'createdAt',
          'updatedAt'
        ])
        && hasOnly(data, [
          'uid',
          'callSign',
          'handle',
          'bestScore',
          'phase',
          'achievementsCount',
          'glory',
          'gloryRank',
          'gloryRankIndex',
          'seasonTier',
          'createdAt',
          'updatedAt'
        ])
        && data.uid == userId
        && validCallSign(data.callSign)
        && validHandle(data.handle)
        && validScore(data.bestScore)
        && validPhase(data.phase)
        && validCounter(data.achievementsCount)
        && validScore(data.glory)
        && validGloryRank(data.gloryRank)
        && validGloryRankIndex(data.gloryRankIndex)
        && validSeasonTier(data.seasonTier)
        && data.updatedAt == request.time;
    }

    function validLeaderboardRecord(data, userId) {
      return hasRequired(data, [
          'uid',
          'callSign',
          'handle',
          'bestScore',
          'phase',
          'achievementsCount',
          'glory',
          'gloryRank',
          'gloryRankIndex',
          'seasonTier',
          'updatedAt'
        ])
        && hasOnly(data, [
          'uid',
          'callSign',
          'handle',
          'bestScore',
          'phase',
          'achievementsCount',
          'glory',
          'gloryRank',
          'gloryRankIndex',
          'seasonTier',
          'updatedAt'
        ])
        && data.uid == userId
        && validCallSign(data.callSign)
        && validHandle(data.handle)
        && validScore(data.bestScore)
        && validPhase(data.phase)
        && validCounter(data.achievementsCount)
        && validScore(data.glory)
        && validGloryRank(data.gloryRank)
        && validGloryRankIndex(data.gloryRankIndex)
        && validSeasonTier(data.seasonTier)
        && data.updatedAt == request.time;
    }

    function validAchievementId(achievementId) {
      return achievementId in [
        'first_sortie',
        'rookie_score',
        'ace_score',
        'legend_score',
        'surge_score',
        'mythic_score',
        'phase_two',
        'phase_three',
        'phase_eight',
        'phase_twelve',
        'boss_breaker',
        'boss_hunter',
        'ghost_runner',
        'collector',
        'power_hungry',
        'swarm_clearer'
      ];
    }

    function validAchievement(data, userId, achievementId) {
      return hasRequired(data, [
          'uid',
          'achievementId',
          'title',
          'unlockedAt'
        ])
        && hasOnly(data, [
          'uid',
          'achievementId',
          'title',
          'unlockedAt'
        ])
        && validAchievementId(achievementId)
        && data.uid == userId
        && data.achievementId == achievementId
        && validText(data.title, 40)
        && data.unlockedAt == request.time;
    }

    function validRunReceipt(data, userId, receiptId) {
      return hasRequired(data, [
          'uid',
          'receiptId',
          'clientReceiptId',
          'score',
          'phaseReached',
          'runDurationMs',
          'enemiesKilled',
          'bossesKilled',
          'powerupsCollected',
          'ghostUses',
          'damageTaken',
          'highestCombo',
          'gloryGained',
          'seasonXPGained',
          'creditsEarned',
          'clientVersion',
          'endedAtMs',
          'submittedAt'
        ])
        && hasOnly(data, [
          'uid',
          'receiptId',
          'clientReceiptId',
          'score',
          'phaseReached',
          'runDurationMs',
          'enemiesKilled',
          'bossesKilled',
          'powerupsCollected',
          'ghostUses',
          'damageTaken',
          'highestCombo',
          'gloryGained',
          'seasonXPGained',
          'creditsEarned',
          'clientVersion',
          'endedAtMs',
          'submittedAt'
        ])
        && data.uid == userId
        && data.receiptId == receiptId
        && validSeasonId(data.clientReceiptId)
        && validScore(data.score)
        && validPhase(data.phaseReached)
        && validBoundedCounter(data.runDurationMs, 86400000)
        && validCounter(data.enemiesKilled)
        && validCounter(data.bossesKilled)
        && validCounter(data.powerupsCollected)
        && validCounter(data.ghostUses)
        && validCounter(data.damageTaken)
        && validCounter(data.highestCombo)
        && validScore(data.gloryGained)
        && validBoundedCounter(data.seasonXPGained, 2500)
        && validBoundedCounter(data.creditsEarned, 1500)
        && validText(data.clientVersion, 20)
        && validBoundedCounter(data.endedAtMs, 9999999999999)
        && data.submittedAt == request.time;
    }

    match /players_private/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /players_public/{userId} {
      allow get: if signedIn();
      allow list: if signedIn() && request.query.limit <= 25;
      allow create, update, delete: if false;
    }

    match /leaderboard_scores/{userId} {
      allow get: if signedIn();
      allow list: if signedIn() && request.query.limit <= 25;
      allow create, update, delete: if false;
    }

    match /player_achievements/{userId}/items/{achievementId} {
      allow get, list: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /run_receipts/{userId}/items/{receiptId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId) && request.query.limit <= 50;
      allow create, update, delete: if false;
    }

    match /season_reward_claims/{userId}/items/{rewardId} {
      allow get, list: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /handle_registry/{handle} {
      allow read, write: if false;
    }

    match /weekly_enrollments/{enrollmentId} {
      allow read, write: if false;
    }

    match /weekly_leagues/{leagueId} {
      allow read, write: if false;

      match /members/{userId} {
        allow read, write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
