rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasRequired(data, fields) {
      return data.keys().hasAll(fields);
    }

    function hasOnly(data, fields) {
      return data.keys().hasOnly(fields);
    }

    function validText(value, maxLength) {
      return value is string
        && value.size() <= maxLength
        && value.matches("^[A-Za-z0-9 _.'-]*$");
    }

    function validEmail(value) {
      return value is string
        && value.size() <= 120
        && value.matches("^[A-Za-z0-9@._+-]*$");
    }

    function validCallSign(value) {
      return value is string
        && value.size() <= 12
        && value.matches("^[A-Z0-9_]*$");
    }

    function validUrl(value) {
      return value is string
        && value.size() <= 300
        && (value == "" || value.matches("^https?://.{1,292}$"));
    }

    function validScore(value) {
      return value is int && value >= 0 && value <= 999999999;
    }

    function validCounter(value) {
      return value is int && value >= 0 && value <= 1000000;
    }

    function validBoundedCounter(value, max) {
      return value is int && value >= 0 && value <= max;
    }

    function validPhase(value) {
      return value is int && value >= 1 && value <= 9999;
    }

    function validGloryRank(value) {
      return value in [
        'Rookie Pilot',
        'Star Cadet',
        'Strike Pilot',
        'Void Runner',
        'Ace',
        'Elite Ace',
        'Phantom Hunter',
        'Wraithbreaker',
        'Solar Legend',
        'Star Eternal'
      ];
    }

    function validGloryRankIndex(value) {
      return value is int && value >= 0 && value <= 9;
    }

    function validSeasonId(value) {
      return value is string
        && value.size() >= 1
        && value.size() <= 40
        && value.matches("^[A-Za-z0-9_-]+$");
    }

    function validSeasonTier(value) {
      return value is int && value >= 1 && value <= 50;
    }

    function validSeasonClaimedRewardIds(value) {
      return value is list && value.size() <= 220;
    }

    function validPrivateAccount(data, userId) {
      return hasRequired(data, [
          'uid',
          'email',
          'displayName',
          'photoURL',
          'glory',
          'gloryRank',
          'gloryRankIndex',
          'currentSeasonId',
          'currentSeasonXP',
          'currentSeasonTier',
          'credits',
          'seasonClaimedRewardIds',
          'lifetimeRuns',
          'lifetimeScore',
          'lifetimeKills',
          'lifetimePowerups',
          'lifetimeGhostUses',
          'lifetimeBosses',
          'lifetimeDamageTaken',
          'highestCombo',
          'createdAt',
          'lastSeenAt',
          'updatedAt'
        ])
        && hasOnly(data, [
          'uid',
          'email',
          'displayName',
          'photoURL',
          'glory',
          'gloryRank',
          'gloryRankIndex',
          'currentSeasonId',
          'currentSeasonXP',
          'currentSeasonTier',
          'credits',
          'seasonClaimedRewardIds',
          'lifetimeRuns',
          'lifetimeScore',
          'lifetimeKills',
          'lifetimePowerups',
          'lifetimeGhostUses',
          'lifetimeBosses',
          'lifetimeDamageTaken',
          'highestCombo',
          'createdAt',
          'lastSeenAt',
          'updatedAt'
        ])
        && data.uid == userId
        && validEmail(data.email)
        && validText(data.displayName, 60)
        && validUrl(data.photoURL)
        && validScore(data.glory)
        && validGloryRank(data.gloryRank)
        && validGloryRankIndex(data.gloryRankIndex)
        && validSeasonId(data.currentSeasonId)
        && validScore(data.currentSeasonXP)
        && validSeasonTier(data.currentSeasonTier)
        && validScore(data.credits)
        && validSeasonClaimedRewardIds(data.seasonClaimedRewardIds)
        && validCounter(data.lifetimeRuns)
        && validScore(data.lifetimeScore)
        && validCounter(data.lifetimeKills)
        && validCounter(data.lifetimePowerups)
        && validCounter(data.lifetimeGhostUses)
        && validCounter(data.lifetimeBosses)
        && validCounter(data.lifetimeDamageTaken)
        && validCounter(data.highestCombo)
        && data.lastSeenAt == request.time
        && data.updatedAt == request.time;
    }

    function validPublicProfile(data, userId) {
      return hasRequired(data, [
          'uid',
          'callSign',
          'bestScore',
          'phase',
          'achievementsCount',
          'glory',
          'gloryRank',
          'gloryRankIndex',
          'seasonTier',
          'createdAt',
          'updatedAt'
        ])
        && hasOnly(data, [
          'uid',
          'callSign',
          'bestScore',
          'phase',
          'achievementsCount',
          'glory',
          'gloryRank',
          'gloryRankIndex',
          'seasonTier',
          'createdAt',
          'updatedAt'
        ])
        && data.uid == userId
        && validCallSign(data.callSign)
        && validScore(data.bestScore)
        && validPhase(data.phase)
        && validCounter(data.achievementsCount)
        && validScore(data.glory)
        && validGloryRank(data.gloryRank)
        && validGloryRankIndex(data.gloryRankIndex)
        && validSeasonTier(data.seasonTier)
        && data.updatedAt == request.time;
    }

    function validLeaderboardRecord(data, userId) {
      return hasRequired(data, [
          'uid',
          'callSign',
          'bestScore',
          'phase',
          'achievementsCount',
          'glory',
          'gloryRank',
          'gloryRankIndex',
          'seasonTier',
          'updatedAt'
        ])
        && hasOnly(data, [
          'uid',
          'callSign',
          'bestScore',
          'phase',
          'achievementsCount',
          'glory',
          'gloryRank',
          'gloryRankIndex',
          'seasonTier',
          'updatedAt'
        ])
        && data.uid == userId
        && validCallSign(data.callSign)
        && validScore(data.bestScore)
        && validPhase(data.phase)
        && validCounter(data.achievementsCount)
        && validScore(data.glory)
        && validGloryRank(data.gloryRank)
        && validGloryRankIndex(data.gloryRankIndex)
        && validSeasonTier(data.seasonTier)
        && data.updatedAt == request.time;
    }

    function validAchievementId(achievementId) {
      return achievementId in [
        'first_sortie',
        'rookie_score',
        'ace_score',
        'legend_score',
        'surge_score',
        'mythic_score',
        'phase_two',
        'phase_three',
        'phase_eight',
        'phase_twelve',
        'boss_breaker',
        'boss_hunter',
        'ghost_runner',
        'collector',
        'power_hungry',
        'swarm_clearer'
      ];
    }

    function validAchievement(data, userId, achievementId) {
      return hasRequired(data, [
          'uid',
          'achievementId',
          'title',
          'unlockedAt'
        ])
        && hasOnly(data, [
          'uid',
          'achievementId',
          'title',
          'unlockedAt'
        ])
        && validAchievementId(achievementId)
        && data.uid == userId
        && data.achievementId == achievementId
        && validText(data.title, 40)
        && data.unlockedAt == request.time;
    }

    function validRunReceipt(data, userId, receiptId) {
      return hasRequired(data, [
          'uid',
          'receiptId',
          'clientReceiptId',
          'score',
          'phaseReached',
          'runDurationMs',
          'enemiesKilled',
          'bossesKilled',
          'powerupsCollected',
          'ghostUses',
          'damageTaken',
          'highestCombo',
          'gloryGained',
          'seasonXPGained',
          'creditsEarned',
          'clientVersion',
          'endedAtMs',
          'submittedAt'
        ])
        && hasOnly(data, [
          'uid',
          'receiptId',
          'clientReceiptId',
          'score',
          'phaseReached',
          'runDurationMs',
          'enemiesKilled',
          'bossesKilled',
          'powerupsCollected',
          'ghostUses',
          'damageTaken',
          'highestCombo',
          'gloryGained',
          'seasonXPGained',
          'creditsEarned',
          'clientVersion',
          'endedAtMs',
          'submittedAt'
        ])
        && data.uid == userId
        && data.receiptId == receiptId
        && validSeasonId(data.clientReceiptId)
        && validScore(data.score)
        && validPhase(data.phaseReached)
        && validBoundedCounter(data.runDurationMs, 86400000)
        && validCounter(data.enemiesKilled)
        && validCounter(data.bossesKilled)
        && validCounter(data.powerupsCollected)
        && validCounter(data.ghostUses)
        && validCounter(data.damageTaken)
        && validCounter(data.highestCombo)
        && validScore(data.gloryGained)
        && validBoundedCounter(data.seasonXPGained, 2500)
        && validBoundedCounter(data.creditsEarned, 1500)
        && validText(data.clientVersion, 20)
        && validBoundedCounter(data.endedAtMs, 9999999999999)
        && data.submittedAt == request.time;
    }

    match /players_private/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId)
        && validPrivateAccount(request.resource.data, userId)
        && request.resource.data.createdAt == request.time;
      allow update: if isOwner(userId)
        && validPrivateAccount(request.resource.data, userId)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.glory >= resource.data.get('glory', 0)
        && request.resource.data.gloryRankIndex >= resource.data.get('gloryRankIndex', 0)
        && request.resource.data.currentSeasonXP >= resource.data.get('currentSeasonXP', 0)
        && request.resource.data.currentSeasonTier >= resource.data.get('currentSeasonTier', 1)
        && request.resource.data.credits >= resource.data.get('credits', 0)
        && request.resource.data.lifetimeRuns >= resource.data.get('lifetimeRuns', 0)
        && request.resource.data.lifetimeScore >= resource.data.get('lifetimeScore', 0)
        && request.resource.data.lifetimeKills >= resource.data.get('lifetimeKills', 0)
        && request.resource.data.lifetimePowerups >= resource.data.get('lifetimePowerups', 0)
        && request.resource.data.lifetimeGhostUses >= resource.data.get('lifetimeGhostUses', 0)
        && request.resource.data.lifetimeBosses >= resource.data.get('lifetimeBosses', 0)
        && request.resource.data.lifetimeDamageTaken >= resource.data.get('lifetimeDamageTaken', 0)
        && request.resource.data.highestCombo >= resource.data.get('highestCombo', 0);
      allow delete: if false;
    }

    match /players_public/{userId} {
      allow get: if signedIn();
      allow list: if signedIn() && request.query.limit <= 25;
      allow create: if isOwner(userId)
        && validPublicProfile(request.resource.data, userId)
        && request.resource.data.createdAt == request.time;
      allow update: if isOwner(userId)
        && validPublicProfile(request.resource.data, userId)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.bestScore >= resource.data.bestScore
        && request.resource.data.phase >= resource.data.phase
        && request.resource.data.achievementsCount >= resource.data.achievementsCount
        && request.resource.data.glory >= resource.data.get('glory', 0)
        && request.resource.data.gloryRankIndex >= resource.data.get('gloryRankIndex', 0)
        && request.resource.data.seasonTier >= resource.data.get('seasonTier', 1);
      allow delete: if false;
    }

    match /leaderboard_scores/{userId} {
      allow get: if signedIn();
      allow list: if signedIn() && request.query.limit <= 25;
      allow create: if isOwner(userId)
        && validLeaderboardRecord(request.resource.data, userId);
      allow update: if isOwner(userId)
        && validLeaderboardRecord(request.resource.data, userId)
        && request.resource.data.bestScore >= resource.data.bestScore
        && request.resource.data.phase >= resource.data.phase
        && request.resource.data.achievementsCount >= resource.data.achievementsCount
        && request.resource.data.glory >= resource.data.get('glory', 0)
        && request.resource.data.gloryRankIndex >= resource.data.get('gloryRankIndex', 0)
        && request.resource.data.seasonTier >= resource.data.get('seasonTier', 1);
      allow delete: if false;
    }

    match /player_achievements/{userId}/items/{achievementId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId)
        && validAchievement(request.resource.data, userId, achievementId);
      allow update, delete: if false;
    }

    match /run_receipts/{userId}/items/{receiptId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId) && request.query.limit <= 50;
      allow create: if isOwner(userId)
        && validRunReceipt(request.resource.data, userId, receiptId);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
